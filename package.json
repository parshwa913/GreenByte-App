{
  "name": "greenbyte-customer-app",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --web",
    "mobile": "expo start --lan -c --port 8082",
    "mobile:lan": "expo start --lan -c --port 8082",
    "mobile:tunnel": "expo start --tunnel -c --port 8082",
    "mobile:usb": "adb reverse tcp:8082 tcp:8082 && expo start --localhost -c --port 8082",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "backend:seed": "npm --prefix backend run seed",
    "backend:pipeline": "npm --prefix backend run pipeline"
  },
  "dependencies": {
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-firebase-recaptcha": "^2.3.1",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "babel-preset-expo": "~54.0.10"
  }
}
